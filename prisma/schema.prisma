// Prisma Schema for Meet Cute

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  timezone  String   @default("America/New_York") // User's IANA timezone (e.g., "America/New_York", "Europe/London")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Onboarding
  onboardingCompleted Boolean @default(false)
  onboardingData      Json?   // Stores: workStart, workEnd, focusGoals, customGoal, meetingComfort, meetingsPerDay, directorsNote

  // Calendar Integrations
  calendarAccounts CalendarAccount[]

  // Preferences
  preferences UserPreferences?

  // Meetings & History
  meetings           Meeting[]
  focusSessions      FocusSession[]
  dailyReflections   DailyReflection[]
  wellnessCheckIns   WellnessCheckIn[]
  presleyFlowSessions PresleyFlowSession[]
  windingDownSessions WindingDownSession[]

  // Delivery Settings
  deliverySettings DeliverySettings?
  
  // Push Notifications
  pushSubscriptions PushSubscription[]
  
  // Cue Companion
  cueSettings CueSettings?
  cueTelemetry CueTelemetry[]
  meetingMoods MeetingMood[]

  @@map("users")
}

model CalendarAccount {
  id           String   @id @default(uuid())
  userId       String
  provider     String   // "google" or "microsoft"
  email        String
  label        String   @default("")
  color        String?  // optional hex color for UI badges
  isPrimary    Boolean  @default(false)
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetings Meeting[]

  @@unique([userId, provider, email])
  @@map("calendar_accounts")
}

model UserPreferences {
  id        String   @id @default(uuid())
  userId    String   @unique
  tone      String   @default("balanced") // "executive", "cinematic", "balanced", "calm"
  
  // Timing preferences
  alertMinutesBefore Int @default(10)
  mergeBackToBack    Boolean @default(true)
  
  // Feature toggles
  enableDailyWrapUp    Boolean @default(true)
  enableFocusScene     Boolean @default(true)
  enableAdaptiveTiming Boolean @default(false)
  
  // Sound preferences
  enableFocusSound     Boolean @default(true)
  focusSoundType       String  @default("calm-ocean") // "calm-ocean", "rain", "forest", "meditation-bell", "white-noise", "none"
  enableVoiceNarration Boolean @default(true)  // Enable voice narration in flows
  
  // Presley Flow preferences
  morningFlowTime      String  @default("06:00") // Time when morning flow becomes available (HH:mm format)
  
  // Privacy & Reflection preferences
  enableReflections         Boolean @default(true)   // Enable post-meeting reflection prompts
  privateReflectionMode     Boolean @default(false)  // Private mode: only show trends, no raw text/words
  reflectionDataSharing     Boolean @default(false)  // Allow anonymized data for product improvements
  storeReflectionText       Boolean @default(true)   // Store one-word descriptions (can be disabled)
  eveningFlowTime      String  @default("18:00") // Time when evening flow becomes available (HH:mm format)
  enableMorningFlow    Boolean @default(true)  // Enable morning prep/recap
  enableEveningFlow    Boolean @default(true)  // Enable evening wrap-up + mental rehearsal
  
  // Wellness reminders (9am-6pm window)
  enableWellnessReminders Boolean @default(true)  // Enable daily wellness check-ins
  wellnessReminderFrequency Int @default(3)      // Hours between reminders (default: 3 hours)
  
  // Winding Down session (separate from evening flow)
  enableWindingDown    Boolean @default(true)   // Enable standalone winding down session
  windingDownTime      String  @default("21:00") // Time for winding down session (HH:mm format, default: 9 PM)
  
  // Adaptive learning data
  averageEarlyJoinMinutes Float? // How early user typically joins
  preferredAlertTime      Int?   // Learned optimal alert time
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model DeliverySettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  
  // Delivery channels
  emailEnabled   Boolean @default(true)
  slackEnabled   Boolean @default(false)
  smsEnabled     Boolean @default(false)
  pushEnabled    Boolean @default(true)  // Master toggle for web push notifications
  
  // Granular push notification preferences (only applies if pushEnabled is true)
  pushPreMeetingCues      Boolean @default(true)  // Pre-meeting focus session alerts
  pushPresleyFlow         Boolean @default(true)  // Morning/evening Presley Flow alerts
  pushWellnessReminders   Boolean @default(true)  // Wellness check-in reminders
  pushMeetingInsights     Boolean @default(true)  // Post-meeting insights
  pushMorningRecap        Boolean @default(true)  // Morning recap notifications
  pushDailyWrapUp         Boolean @default(true)  // Evening wrap-up notifications
  pushWindingDown         Boolean @default(true)  // Winding down session notifications
  
  // Contact info
  phoneNumber     String?
  slackWebhookUrl String? // Legacy webhook support
  
  // Slack OAuth tokens (preferred method)
  slackAccessToken  String? // OAuth access token
  slackTeamId       String? // Slack workspace ID
  slackTeamName     String? // Slack workspace name
  slackChannelId    String? // Channel where notifications go
  slackChannelName  String? // Channel name for display
  slackUserId       String? // Slack user ID who authorized
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("delivery_settings")
}

model Meeting {
  id              String    @id @default(uuid())
  userId          String
  calendarEventId String    // External calendar event ID
  calendarAccountId String?
  calendarLabel     String?
  calendarColor     String?
  calendarProvider  String?
  
  calendarAccount CalendarAccount? @relation(fields: [calendarAccountId], references: [id], onDelete: SetNull)
  
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime
  attendees       String[]  // Array of email addresses
  location        String?
  meetingLink     String?
  
  // Meeting metadata
  meetingType     String?   // Inferred type: "one-on-one", "team", "client", etc.
  isOrganizer     Boolean   @default(false) // Is user the meeting organizer/host?
  attendeeCount   Int       @default(0)     // Number of attendees in the meeting
  isBackToBack    Boolean   @default(false)
  status          String    @default("scheduled") // scheduled, active, ended
  statusSource    String?   // google_meet, microsoft_graph, heuristic
  actualStartTime DateTime?
  actualEndTime   DateTime?
  lastPresenceCheck DateTime?
  
  // Cue delivery
  cueScheduledFor DateTime?
  cueSentAt       DateTime?
  cueDelivered    Boolean   @default(false)
  cueContent      String?   // The actual message sent
  
  // Focus Scene
  focusSceneUrl   String?
  focusSceneOpened Boolean  @default(false)
  
  // Post-meeting insights
  postMeetingEmailSent Boolean @default(false)
  postMeetingEmailSentAt DateTime?
  meetingRating   Int?      // 1-5 star rating
  meetingMood     String?   // User's mood during meeting: confident, calm, energized, focused, overwhelmed, uncertain
  
  // Post-meeting reflection (new cinematic system)
  reflectionRating    String?   // "great", "neutral", "draining"
  reflectionOneWord   String?   // One word to describe the meeting
  reflectionEmotionalTone String? // AI-analyzed emotional tone
  reflectionCapturedAt DateTime? // When reflection was captured
  reflectionNotes     String?   // Optional longer reflection
  meetingFeedback String?   // Optional user feedback
  ratedAt         DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusSession  FocusSession?
  cueTelemetry  CueTelemetry[]
  meetingMoods  MeetingMood[]

  @@unique([userId, calendarEventId])
  @@index([userId, startTime])
  @@index([cueScheduledFor])
  @@map("meetings")
}

model FocusSession {
  id              String    @id @default(uuid())
  userId          String
  meetingId       String    @unique
  
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  duration        Int?      // Duration in seconds
  
  // User interactions
  breathingExerciseCompleted Boolean @default(false)
  reflectionNotes           String?
  intention                 String?  // User's focus/goal for the meeting ("What's your focus for this meeting?")
  
  // Mind state tracking
  mindState       String?   // "calm", "stressed", "focused", "unclear"
  breathingFlowType String? // Type of breathing flow used based on mind state
  
  createdAt       DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("focus_sessions")
}

model DailyReflection {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime @db.Date
  
  totalMeetings       Int
  scenesCompleted     Int
  focusSessionsOpened Int
  
  // Insights
  mostProductiveTime  String? // e.g., "morning", "afternoon"
  averageJoinTime     Float?  // Average minutes before meeting joined
  
  wrapUpSentAt        DateTime?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_reflections")
}

model SystemLog {
  id        String   @id @default(uuid())
  level     String   // "info", "warn", "error"
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@map("system_logs")
}

model WellnessCheckIn {
  id        String   @id @default(uuid())
  userId    String
  type      String   // "breathing", "walk", "mindful_moment"
  completed Boolean  @default(false)
  mindState String?  // User's mind state at check-in
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("wellness_checkins")
}

model PresleyFlowSession {
  id                 String   @id @default(uuid())
  userId             String
  date               DateTime // The date this session is for
  flowType           String   // "morning" or "evening"
  completedAt        DateTime?
  journalNote        String?
  
  // Evening-specific fields
  dailyOutcomes      String?  // AI summary of today's meeting outcomes
  reflectionText     String?  // User's reflection on the day
  performanceRating  Int?     // 1-5 rating of today's performance
  improvementNotes   String?  // What the user wants to improve tomorrow
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, flowType])
  @@index([userId, date])
  @@map("presley_flow_sessions")
}

model PushSubscription {
  id         String   @id @default(uuid())
  userId     String
  endpoint   String   @unique // Push service endpoint URL
  p256dh     String   // Encryption key
  auth       String   // Authentication secret
  userAgent  String?  // Browser/device info
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model WindingDownSession {
  id          String    @id @default(uuid())
  userId      String
  date        DateTime  @default(now()) // The date this session was started
  completedAt DateTime?
  duration    Int?      // Duration in seconds
  createdAt   DateTime  @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, date])
  @@map("winding_down_sessions")
}

model CueSettings {
  id        String   @id @default(uuid())
  userId    String   @unique
  enabled   Boolean  @default(true)
  tone      String   @default("calm") // "calm" or "direct"
  
  // Delivery channels
  toastEnabled  Boolean @default(true)
  slackEnabled  Boolean @default(false)
  
  // Timing & frequency
  quietHours   Json    @default("[]") // Array of { start: "HH:mm", end: "HH:mm" }
  cueFrequency String  @default("balanced") // "minimal", "balanced", "frequent"
  
  // Per-meeting overrides
  perMeetingOverrides Json @default("{}") // Record<meetingId, boolean>
  
  // Low-energy window (for contextual cues)
  lowEnergyStart String @default("14:00") // HH:mm format
  lowEnergyEnd   String @default("16:00")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("cue_settings")
}

model CueTelemetry {
  id         String   @id @default(uuid())
  cueId      String
  meetingId  String?
  userId     String
  action     String   // "clicked", "dismissed", "ignored"
  actionType String?  // "breathe", "focus-note", "hide", etc.
  timestamp  DateTime
  createdAt  DateTime @default(now())
  
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  @@index([userId, timestamp])
  @@index([cueId])
  @@map("cue_telemetry")
}

model MeetingMood {
  id        String   @id @default(uuid())
  meetingId String
  userId    String
  value     Int      // -1 (stressed), 0 (neutral), 1 (energized)
  timestamp DateTime
  createdAt DateTime @default(now())
  
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  @@unique([meetingId, userId])
  @@index([userId])
  @@index([meetingId])
  @@map("meeting_moods")
}

