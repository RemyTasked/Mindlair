<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow app to be run on macOS -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    
    <!-- Allow network access for API calls -->
    <key>com.apple.security.network.client</key>
    <true/>
    
    <!-- Allow reading user-selected files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- Allow automation (for AppleScript browser URL capture) -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
    
    <!-- Allow screen capture (for OCR) -->
    <key>com.apple.security.device.screen-capture</key>
    <true/>
    
    <!-- Allow audio input (for audio capture) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    
    <!-- Allow accessibility (for URL monitoring) -->
    <key>com.apple.security.temporary-exception.apple-events</key>
    <array>
        <string>com.apple.Safari</string>
        <string>com.google.Chrome</string>
        <string>org.mozilla.firefox</string>
        <string>company.thebrowser.Browser</string>
        <string>com.microsoft.edgemac</string>
        <string>com.brave.Browser</string>
    </array>
    
    <!-- For hardened runtime -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
