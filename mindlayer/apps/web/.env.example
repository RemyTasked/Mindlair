# ===========================================
# Mindlayer - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# ===========================================
# REQUIRED - Core
# ===========================================

# Database (PostgreSQL with pgvector extension)
# Install: brew install postgresql@15 pgvector
# Create DB: createdb mindlayer && psql mindlayer -c "CREATE EXTENSION vector;"
DATABASE_URL="postgresql://user:password@localhost:5432/mindlayer?schema=public"

# OpenAI API Key - Powers claim extraction, graph queries, and source chain analysis
# Get yours at: https://platform.openai.com/api-keys
# Model used: gpt-4o-2024-08-06
OPENAI_API_KEY="sk-..."

# App URL (change in production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# REQUIRED - Authentication & Email
# ===========================================

# Resend.com API Key for magic link emails
# Sign up at: https://resend.com
RESEND_API_KEY="re_..."

# Email address for sending authentication emails
FROM_EMAIL="noreply@yourdomain.com"

# ===========================================
# REQUIRED - Push Notifications (PWA)
# ===========================================

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BK..."
VAPID_PRIVATE_KEY="..."
VAPID_SUBJECT="mailto:support@yourdomain.com"

# ===========================================
# OPTIONAL - Third-Party Integrations
# ===========================================

# Pocket Integration
# Get consumer key at: https://getpocket.com/developer/
POCKET_CONSUMER_KEY=""

# Instapaper Integration  
# Request OAuth tokens at: https://www.instapaper.com/main/request_oauth_consumer_token
INSTAPAPER_CONSUMER_KEY=""
INSTAPAPER_CONSUMER_SECRET=""

# Readwise Integration
# Get token at: https://readwise.io/access_token
# Note: Users provide their own token in settings

# ===========================================
# OPTIONAL - Production Settings
# ===========================================

# Set to 'production' in production environment
NODE_ENV="development"
