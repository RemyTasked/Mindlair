{
  "manifest_version": 3,
  "name": "Mind Garden",
  "short_name": "Mind Garden",
  "version": "1.0.0",
  "description": "Calendar-integrated mental fitness tool with contextual micro-interventions for stressed professionals",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Mind Garden"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["content-scripts/google-calendar.js"],
      "css": ["content-scripts/sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://outlook.office.com/calendar/*",
        "https://outlook.live.com/calendar/*"
      ],
      "js": ["content-scripts/outlook-calendar.js"],
      "css": ["content-scripts/sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "identity",
    "storage",
    "alarms",
    "notifications",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://graph.microsoft.com/*",
    "http://localhost:3000/*",
    "https://mindgarden.app/*"
  ],
  "oauth2": {
    "client_id": "317117970533-d1fdfm2o7mok8io6fc4rf5lt14fu45cq.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events.readonly",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "sounds/*", "sidebar/*"],
      "matches": ["https://calendar.google.com/*", "https://outlook.office.com/*", "https://outlook.live.com/*"]
    }
  ]
}
