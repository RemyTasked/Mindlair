{
  "manifest_version": 3,
  "name": "Mindlair",
  "version": "0.1.0",
  "description": "Passively maps what you read, watch, and listen to — building your belief graph over time.",
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@mindlair.app",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "webNavigation",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.mindlair.app/*",
    "https://mindlair-production.up.railway.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "scripts": ["content-filter.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
